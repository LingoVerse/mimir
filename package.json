{
  "name": "mimir",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#app-store": {
      "workerd": "./src/lib/dedup.d1.ts",
      "default": "./src/lib/dedup.node.ts"
    }
  },
  "scripts": {
    "dev": "flue dev --target node",
    "build": "flue build --target node",
    "dev:cf": "flue dev --target cloudflare",
    "build:cf": "flue build --target cloudflare",
    "deploy:cf": "wrangler deploy --config dist/mimir/wrangler.json",
    "cf:dry-run": "wrangler deploy --dry-run --config dist/mimir/wrangler.json",
    "d1:migrate": "wrangler d1 migrations apply mimir --remote",
    "d1:migrate:local": "wrangler d1 migrations apply mimir --local",
    "typecheck": "tsc --noEmit",
    "test": "node --test 'src/**/*.test.ts' 'eval/**/*.test.ts'",
    "test:cf": "vitest run",
    "lint": "oxlint",
    "format": "oxfmt",
    "eval": "node eval/index.ts",
    "eval:no-judge": "node eval/index.ts --no-judge",
    "export-eval-data": "node scripts/export-eval-data.ts"
  },
  "dependencies": {
    "@flue/github": "^1.0.0-beta.1",
    "@flue/runtime": "^1.0.0-beta.9",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.17.0",
    "@cloudflare/workers-types": "^4.20260701.1",
    "@flue/cli": "^1.0.0-beta.9",
    "@types/node": "^26.1.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.72.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.106.0"
  },
  "optionalDependencies": {
    "agents": "^0.14.2"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
