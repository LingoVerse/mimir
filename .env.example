# Copy to .env and fill the three REQUIRED vars. Mimir validates env at startup
# and refuses to boot if a required one is missing. See DEPLOY.md for GitHub setup.

# --- LLM (all model access via OpenRouter; no lab lock-in) ---
OPENROUTER_API_KEY=                                # REQUIRED — https://openrouter.ai/keys
OPENROUTER_REFERER=https://github.com
MODEL_PRIMARY=openrouter/z-ai/glm-5.2              # VERIFY slug in OpenRouter catalog
MODEL_ESCALATION=openrouter/google/gemini-flash-3  # VERIFY slug in OpenRouter catalog
ESCALATION_DIFF_THRESHOLD=400

# --- GitHub ---
GITHUB_WEBHOOK_SECRET=   # REQUIRED — verifies inbound webhooks; generate: openssl rand -hex 32 (set same value in the GitHub webhook)
GITHUB_TOKEN=            # REQUIRED — outbound API: read diff + post comments. Fine-grained PAT: Contents:Read + Pull requests:R/W (see DEPLOY.md)
INTERNAL_BASE_URL=       # optional: loopback the channel uses to admit review-pr runs (e.g. http://localhost:3000 behind a proxy)

# --- Behavior ---
POST_NITS=false
DIFF_MAX_TOKENS=60000   # cap reviewed diff size; largest-change files kept, rest noted as truncated

# --- Storage (dedup of delivery IDs + summary comment-ID tracking) ---
DATABASE_URL=sqlite:./data/mimir.db   # sqlite only in this build; defaults to ./data/mimir.db when unset
