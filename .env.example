# Copy to .env and fill the three REQUIRED vars. Mimir validates env at startup
# and refuses to boot if a required one is missing. See DEPLOY.md for GitHub setup.

# --- LLM (all model access via OpenRouter; no lab lock-in) ---
OPENROUTER_API_KEY=                                # REQUIRED — https://openrouter.ai/keys
OPENROUTER_REFERER=https://github.com
MODEL_PRIMARY=openrouter/google/gemini-3-flash-preview   # cheap pass, runs on every PR
MODEL_ESCALATION=openrouter/z-ai/glm-5.2                 # stronger pass on hard diffs
ESCALATION_DIFF_THRESHOLD=400
ESCALATE_SECURITY_ALWAYS=true

# --- GitHub ---
GITHUB_WEBHOOK_SECRET=   # REQUIRED — verifies inbound webhooks; generate: openssl rand -hex 32
GITHUB_TOKEN=            # REQUIRED — outbound API: read diff + post comments
MIMIR_HANDLE=mimir       # GitHub handle for @handle remember / @handle review commands

# --- Behavior ---
POST_NITS=false
DIFF_MAX_TOKENS=60000
SKIP_LABELS=mimir:skip   # comma-separated PR labels that exclude the whole PR from review

# --- Review tool budget ---
REPO_TOOL_CALL_BUDGET=     # pin per-pass tool calls (default: auto ~1/reviewed file, floored 8, capped 40)
REPO_TOOL_CALL_BUDGET_MAX= # cap auto-scaling (default: 40)

# --- Storage (dedup, comment-ID tracking, review stats) ---
DATABASE_URL=sqlite:./data/mimir.db
